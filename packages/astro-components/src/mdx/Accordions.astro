---
interface Props {
  multiple?: boolean;
  defaultValue?: string | string[];
}

const { multiple = false, defaultValue } = Astro.props;
const defaultValues =
  typeof defaultValue === 'string'
    ? [defaultValue]
    : Array.isArray(defaultValue)
      ? defaultValue
      : [];
---

<div
  class="pf-accordions"
  data-default-values={JSON.stringify(defaultValues)}
  data-multiple={multiple ? 'true' : undefined}
  data-pf-accordions
>
  <slot />
</div>

<script>
  import '../client/accordions';
</script>

<style is:global>
  .pf-accordions {
    border-bottom: 1px solid
      color-mix(in oklab, var(--pf-text-muted, #667085) 18%, transparent);
    border-top: 1px solid
      color-mix(in oklab, var(--pf-text-muted, #667085) 18%, transparent);
    margin-block: 1.5rem;
  }

  .pf-accordion {
    border-bottom: 1px solid
      color-mix(in oklab, var(--pf-text-muted, #667085) 18%, transparent);
  }

  .pf-accordion:last-child {
    border-bottom: 0;
  }

  .pf-accordion__trigger {
    align-items: center;
    color: var(--pf-text-strong, var(--pf-text, #182230));
    cursor: pointer;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    list-style: none;
    padding-block: 1rem;
    text-align: left;
    transition: color 160ms ease;
  }

  .pf-accordion__trigger::-webkit-details-marker {
    display: none;
  }

  .pf-accordion__trigger:hover {
    color: var(--pf-accent, #4f46e5);
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .pf-accordion__trigger:focus-visible {
    border-radius: var(--pf-radius-md, 0.5rem);
    outline: 2px solid var(--pf-accent, #4f46e5);
    outline-offset: 2px;
  }

  .pf-accordion__title {
    font-size: 0.9375rem;
    font-weight: 500;
    line-height: 1.5rem;
  }

  .pf-accordion__chevron {
    color: var(--pf-text-muted, #667085);
    display: inline-flex;
    flex: 0 0 auto;
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .pf-accordion[open] > .pf-accordion__trigger .pf-accordion__chevron {
    transform: rotate(180deg);
  }

  .pf-accordion__trigger:hover .pf-accordion__chevron {
    color: currentColor;
  }

  .pf-accordion__content {
    color: var(--pf-text, #344054);
    font-size: 0.9375rem;
    line-height: 1.75;
    padding-block: 0 1rem;
  }

  .pf-accordion__content > :first-child {
    margin-block-start: 0;
  }

  .pf-accordion__content > :last-child {
    margin-block-end: 0;
  }

  .pf-accordion__content > * + * {
    margin-block-start: 0.75rem;
  }

  .pf-accordion[data-disabled='true'] {
    opacity: 0.55;
  }

  .pf-accordion[data-disabled='true'] > .pf-accordion__trigger {
    cursor: not-allowed;
    text-decoration: none;
  }
</style>
