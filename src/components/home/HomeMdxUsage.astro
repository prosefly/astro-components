---
import { Icon } from '@prosefly/astro-components';
import { PageSection } from '@prosefly/astro-theme-lotus/layouts';
---

<PageSection class="border-b border-(--lotus-border-subtle) bg-(--lotus-surface)/55" padding="lg" size="xl">
  <div class="grid gap-12 lg:grid-cols-[minmax(0,0.8fr)_minmax(30rem,1fr)] lg:items-center">
    <div>
      <p class="section-label">Use it directly</p>
      <h2 class="section-heading mt-3">Import components in any Astro MDX page.</h2>
      <p class="mt-5 max-w-xl text-lg leading-8 text-(--lotus-text-muted)">
        Components ship as Astro files with CSS custom property fallbacks, so
        they can live inside Lotus or your own documentation shell.
      </p>
      <a class="text-link lotus-focus-ring mt-8" href="/docs/installation/">
        Read the installation guide <Icon name="lucide:arrow-right" />
      </a>
    </div>

    <div class="code-window overflow-hidden border border-(--lotus-border-subtle) bg-(--lotus-background)">
      <div class="flex items-center justify-between border-b border-(--lotus-border-subtle) bg-(--lotus-surface) px-4 py-3">
        <span class="font-mono text-xs text-(--lotus-text-muted)">example.mdx</span>
        <span class="flex items-center gap-1.5 text-xs text-(--lotus-text-subtle)">
          <span class="size-1.5 rounded-full bg-emerald-500"></span>
          Ready
        </span>
      </div>
      <pre class="m-0 overflow-x-auto border-0 bg-transparent p-5 text-sm leading-7 text-(--lotus-text)" aria-label="MDX usage example"><code><span class="syntax-keyword">import</span> &#123; <span class="syntax-function">Callout</span>, <span class="syntax-function">Tabs</span>, <span class="syntax-function">TabItem</span> &#125; <span class="syntax-keyword">from</span> <span class="syntax-string">'@prosefly/astro-components'</span>;

&lt;<span class="syntax-function">Callout</span> <span class="syntax-property">type</span>=<span class="syntax-string">"tip"</span> <span class="syntax-property">title</span>=<span class="syntax-string">"Reusable"</span>&gt;
  Add structured content without rebuilding doc UI.
&lt;/<span class="syntax-function">Callout</span>&gt;</code></pre>
    </div>
  </div>
</PageSection>

<style>
  .section-label {
    color: var(--lotus-text-muted);
    font-family: var(--lotus-font-mono);
    font-size: 0.8125rem;
  }

  .section-heading {
    color: var(--lotus-text-strong);
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 600;
    letter-spacing: 0;
    line-height: 1.08;
    max-width: 46rem;
  }

  .text-link {
    align-items: center;
    border-radius: var(--lotus-radius-sm);
    color: var(--lotus-accent);
    display: inline-flex;
    font-size: 0.875rem;
    font-weight: 600;
    gap: 0.5rem;
  }

  .text-link :global(.pl-icon) {
    height: 1rem;
    width: 1rem;
  }

  .code-window {
    --home-syntax-keyword: #cf222e;
    --home-syntax-function: #8250df;
    --home-syntax-property: #0550ae;
    --home-syntax-string: #0a3069;
    border-radius: min(var(--lotus-radius-lg), 1rem);
  }

  .code-window pre {
    background: var(--lotus-code-background);
    font-family: var(--lotus-font-mono);
  }

  .code-window code {
    color: inherit;
    font: inherit;
  }

  .syntax-keyword {
    color: var(--home-syntax-keyword);
  }

  .syntax-function {
    color: var(--home-syntax-function);
  }

  .syntax-property {
    color: var(--home-syntax-property);
  }

  .syntax-string {
    color: var(--home-syntax-string);
  }

  :global(:root[data-theme="dark"]) .code-window {
    --home-syntax-keyword: #ff7b72;
    --home-syntax-function: #d2a8ff;
    --home-syntax-property: #79c0ff;
    --home-syntax-string: #a5d6ff;
  }

  @media (prefers-color-scheme: dark) {
    :global(:root[data-theme="system"]) .code-window {
      --home-syntax-keyword: #ff7b72;
      --home-syntax-function: #d2a8ff;
      --home-syntax-property: #79c0ff;
      --home-syntax-string: #a5d6ff;
    }
  }
</style>
