{
  "name": "astro-components",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "license": "BSD-3-Clause",
  "scripts": {
    "dev": "pnpm run build:pkg && astro dev",
    "build": "pnpm run build:pkg && astro build",
    "build:pkg": "pnpm --dir packages/astro-components build",
    "preview": "astro preview",
    "check": "pnpm run check:pkg && pnpm run build:pkg && pnpm run check:site",
    "check:pkg": "pnpm --dir packages/astro-components check",
    "check:site": "astro check",
    "test": "pnpm --dir packages/astro-components test"
  },
  "dependencies": {
    "@astrojs/check": "latest",
    "@prosefly/astro-components": "workspace:*",
    "@prosefly/astro-theme-lotus": "^0.6.0",
    "astro": "^7.1.3",
    "typescript": "^7.0.2"
  }
}
